{
  "expo": {
    "name": "meuApp",
    "slug": "meuApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/SenaiLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/SenaiLogo2.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E4194"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E4194"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/SenaiLogo2.png"
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
